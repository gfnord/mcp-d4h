# D4H Personal Access Token (PAT) for the Team Manager API.
# Generate from the D4H web UI: User menu -> Manage Account -> Personal Access
# Tokens. See https://help.d4h.com/article/374-api-quick-start-guide for D4H's
# own quick-start guide.

# Required. PAT scoped for the Team Manager API.
D4H_TEAM_MANAGER_API_KEY=

# Required. Numeric team ID visible in the Team Manager URL.
D4H_TEAM_ID=

# Region: US (default), EU, or CA. Controls the host suffix used for the API.
D4H_REGION=US

# Optional. Per-request timeout in milliseconds. Defaults to 30000.
D4H_HTTP_TIMEOUT_MS=30000
